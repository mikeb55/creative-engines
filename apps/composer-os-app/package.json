{
  "name": "composer-os-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:api\"",
    "dev:vite": "vite",
    "dev:api": "cd ../.. && npx ts-node --project tsconfig.json scripts/startComposerOsAppApi.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cd ../.. && npx ts-node --project tsconfig.json scripts/startComposerOsAppApi.ts",
    "test": "npm run build && vitest run"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  }
}
