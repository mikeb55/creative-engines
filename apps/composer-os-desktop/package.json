{
  "name": "composer-os-desktop",
  "version": "1.0.0",
  "description": "Composer OS Windows Desktop Application",
  "main": "dist/main.js",
  "author": "Creative Engines",
  "scripts": {
    "desktop:dev": "npm run build:icon && npm run build:api && npm run build:ui && npm run build:electron && electron .",
    "desktop:build": "npm run build:icon && npm run build:api && npm run build:ui && npm run build:electron",
    "desktop:package": "npm run desktop:build && electron-builder --win",
    "build": "npm run build:api && npm run build:ui && npm run build:electron",
    "build:api": "node scripts/build-api-bundle.js",
    "build:icon": "node scripts/generate-icon.js",
    "build:ui": "cd ../composer-os-app && npm run build && cd ../composer-os-desktop && node scripts/copy-ui.js",
    "build:electron": "tsc -p tsconfig.json",
    "test": "npm run build:icon && npm run build:api && npm run build:ui && npm run build:electron && vitest run",
    "start": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0",
    "vitest": "^1.2.0"
  },
  "build": {
    "appId": "com.creative-engines.composer-os",
    "productName": "Composer OS",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "resources/icon.png",
      "resources/api.bundle.js",
      "resources/ui/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/api.bundle.js",
        "to": "api.bundle.js"
      },
      {
        "from": "resources/ui",
        "to": "ui"
      }
    ],
    "win": {
      "target": ["portable", "nsis"],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "Composer-OS-${version}-portable.exe"
    }
  }
}
